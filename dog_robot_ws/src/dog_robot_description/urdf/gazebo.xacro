<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dog_robot_gazebo">

  <xacro:macro name="foot_friction" params="prefix">
    <gazebo reference="${prefix}_foot_link">
      <mu1>2.0</mu1>
      <mu2>2.0</mu2>
      <kp>5000.0</kp>
      <kd>5.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.1</maxVel>
      <material>Gazebo/DarkGrey</material>
      <self_collide>false</self_collide>
    </gazebo>
  </xacro:macro>

  <xacro:foot_friction prefix="FL"/>
  <xacro:foot_friction prefix="FR"/>
  <xacro:foot_friction prefix="BL"/>
  <xacro:foot_friction prefix="BR"/>

  <xacro:macro name="no_self_collide" params="link">
    <gazebo reference="${link}">
      <self_collide>false</self_collide>
    </gazebo>
  </xacro:macro>

  <!-- Hip meshes overlap base_link bbox; thigh/shank chain may also
       overlap adjacent links. Disable self-collision on every leg
       link so ODE doesn't apply huge separation impulses at spawn. -->
  <xacro:no_self_collide link="FL_hip_link"/>
  <xacro:no_self_collide link="FL_thigh_link"/>
  <xacro:no_self_collide link="FL_shank_link"/>
  <xacro:no_self_collide link="FR_hip_link"/>
  <xacro:no_self_collide link="FR_thigh_link"/>
  <xacro:no_self_collide link="FR_shank_link"/>
  <xacro:no_self_collide link="BL_hip_link"/>
  <xacro:no_self_collide link="BL_thigh_link"/>
  <xacro:no_self_collide link="BL_shank_link"/>
  <xacro:no_self_collide link="BR_hip_link"/>
  <xacro:no_self_collide link="BR_thigh_link"/>
  <xacro:no_self_collide link="BR_shank_link"/>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <self_collide>false</self_collide>
  </gazebo>

  <!-- controllers_yaml_path can be overridden at xacro time; falls back to
       the CHAMP ros_control.yaml so the dog_robot_config/launch/gazebo.launch.py
       path continues to work unchanged. -->
  <xacro:arg name="controllers_yaml_path"
             default="$(find dog_robot_config)/config/ros_control/ros_control.yaml"/>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(arg controllers_yaml_path)</parameters>
    </plugin>
  </gazebo>

</robot>
